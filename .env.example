# ==========================================
# Root Environment Configuration Example
# Copy this file to .env inside respective folders
# ==========================================

# ----------------------------
# Backend (FastAPI) Variables
# ----------------------------
NODE_ENV=development

# Database Configuration (PostgreSQL Asyncpg)
# Use 'postgres' instead of 'localhost' when running inside Docker Compose
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dd_copilot

# Security Configuration
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET_KEY=development-secret-key-must-be-very-long-and-secure-at-least-32-chars
JWT_ALGORITHM=HS256

# Token expiration times
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS allowed origins (comma-separated list)
BACKEND_CORS_ORIGINS=http://localhost:3000

# Cookie Configuration
COOKIE_SECURE=False
COOKIE_SAMESITE=lax

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# OpenAI (required for embedding)
# Generate at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Storage paths (relative to backend/ directory)
STORAGE_PATH=./storage
CHROMA_PATH=./storage/chroma

# ----------------------------
# Frontend (Next.js) Variables
# ----------------------------
# The URL of the FastAPI backend service
NEXT_PUBLIC_API_URL=http://localhost:8000
